AZURE_SPEECH_VOICE_EN=en-US-AvaMultilingualNeural
AZURE_SPEECH_VOICE_ES=es-US-AlonsoNeural
AUDIO_STORAGE_PATH=./tmp/wordsound_audio
ALLOWED_ORIGINS=["http://localhost:5173"]
API_AUDIO_BASE_URL=http://localhost:8000/api/audio
